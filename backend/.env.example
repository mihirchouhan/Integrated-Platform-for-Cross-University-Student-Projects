PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/collegeLoginSystem

# Development mode OTP (no email needed)
OTP_DEV_MODE=true

# OTP email sender (Gmail example)
MAIL_SERVICE=gmail
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_gmail_app_password
MAIL_FROM=your_email@gmail.com

# Auth
JWT_SECRET=change_me_to_a_long_random_secret
